# =====================================================
# Anthropic API
# =====================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# =====================================================
# Database
# PostgreSQL üçün: postgresql://user:password@localhost:5432/contract_analyzer
# SQLite üçün (sınaq):  sqlite:///./contract_analyzer.db
# =====================================================
DATABASE_URL=sqlite:///./contract_analyzer.db

# =====================================================
# Claude Model Settings
# =====================================================
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=8192
CLAUDE_MAX_FUNC_CALLS=6

# =====================================================
# App Settings
# =====================================================
APP_ENV=development
MAX_IMAGES=6
MAX_IMAGE_SIZE_MB=5

# =====================================================
# Debug Mode
# true = terminal-da Claude cavabını və parse status-unu göstər
# false = yalnız xətaları göstər (production üçün)
# =====================================================
DEBUG=false
